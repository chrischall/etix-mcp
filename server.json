{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.chrischall/etix-mcp",
  "description": "Etix event discovery for Claude — search events, venues & performers and fetch event details",
  "repository": {
    "url": "https://github.com/chrischall/etix-mcp",
    "source": "github"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "etix-mcp",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ETIX_WS_PORT",
          "description": "Override the fetchproxy WebSocket port (default 37149).",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ]
}
