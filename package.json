{
  "name": "etix-mcp",
  "version": "0.2.1",
  "mcpName": "io.github.chrischall/etix-mcp",
  "description": "Etix MCP server for Claude — search events, venues & performers and fetch event details",
  "author": "Claude Code (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrischall/etix-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "etix",
    "events",
    "tickets",
    "concerts"
  ],
  "type": "module",
  "bin": {
    "etix-mcp": "dist/bundle.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "server.json",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc --noEmit && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --banner:js='import { createRequire as __createRequire } from \"module\"; const require = __createRequire(import.meta.url);' --outfile=dist/bundle.js",
    "dev": "node dist/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chrischall/mcp-utils": "^0.11.0",
    "@fetchproxy/server": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-html-parser": "^8.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
